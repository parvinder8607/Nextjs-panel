{
  "name": "nextjs-panel",
  "version": "2.0.0",
  "description": "CLI toolkit to scaffold admin panels for Next.js using Prisma",
  "bin": {
    "nextjs-panel": "dist/bin/nextjs-panel.js"
  },
  "scripts": {
  "build": "tsc && copyfiles -u 1 \"src/templates/**/*.ejs\" dist/src/",
  "dev": "tsc && node dist/bin/nextjs-panel.js"
  },
  "keywords": [
    "nextjs",
    "admin",
    "prisma",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.0.3",
    "copyfiles": "^2.4.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ejs": "^5.0.1"
  }
}
