import Link from 'next/link';
import { resourceRegistry } from '<%- resolveImport("panel-resources") %>'; 

export function Sidebar() {
  return (
    <aside className="<%= hasTailwind ? 'w-64 border-r bg-gray-50 h-screen p-4 sticky top-0' : 'admin-sidebar' %>">
      <div className="font-bold text-xl mb-8 px-2">Admin Panel</div>
      
      <nav className="space-y-1">
        <Link 
          href="/admin" 
          className="<%= hasTailwind ? 'block p-2 hover:bg-gray-200 rounded-lg transition-colors' : '' %>"
        >
          Dashboard
        </Link>

        <div className="text-xs font-semibold text-gray-400 uppercase mt-6 mb-2 px-2">
          Resources
        </div>

        {resourceRegistry.map((resource<% if (isTs) { %>: { name: string; slug: string }<% } %>) => (
          <Link 
            key={resource.slug} 
            href={`/admin/${resource.slug}`} 
            className="<%= hasTailwind ? 'block p-2 hover:bg-gray-200 rounded-lg capitalize transition-colors' : '' %>"
          >
            {resource.name}
          </Link>
        ))}
      </nav>
    </aside>
  );
}