import { NextResponse } from 'next/server';
import { PrismaClient } from '@prisma/client';

const prisma = new PrismaClient();

export async function GET(req<%= isTs ? ': Request' : '' %>, { params }<%= isTs ? ': { params: { id: string } }' : '' %>) {
  const item = await prisma.<%= name.toLowerCase() %>.findUnique({ where: { id: params.id } });
  return NextResponse.json(item);
}

export async function PATCH(req<%= isTs ? ': Request' : '' %>, { params }<%= isTs ? ': { params: { id: string } }' : '' %>) {
  const body = await req.json();
  const item = await prisma.<%= name.toLowerCase() %>.update({
    where: { id: params.id },
    data: body
  });
  return NextResponse.json(item);
}

export async function DELETE(req<%= isTs ? ': Request' : '' %>, { params }<%= isTs ? ': { params: { id: string } }' : '' %>) {
  await prisma.<%= name.toLowerCase() %>.delete({ where: { id: params.id } });
  return NextResponse.json({ success: true });
}